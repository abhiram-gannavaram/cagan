{
  "name": "@cagan/vscode-extension",
  "version": "0.1.0",
  "displayName": "cagan",
  "description": "Universal Open-Source AI Coding Agent",
  "publisher": "cagan",
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "activationEvents": [
    "onCommand:cagan.init",
    "onCommand:cagan.agent.run",
    "onCommand:cagan.chat.focus",
    "onView:cagan-sidebar"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cagan.init",
        "title": "cagan: Initialize Project"
      },
      {
        "command": "cagan.agent.run",
        "title": "cagan: Run Agent"
      },
      {
        "command": "cagan.agent.stop",
        "title": "cagan: Stop Agent"
      },
      {
        "command": "cagan.agent.switchMode",
        "title": "cagan: Switch Mode"
      },
      {
        "command": "cagan.chat.focus",
        "title": "cagan: Focus Chat"
      },
      {
        "command": "cagan.memory.view",
        "title": "cagan: View Memory"
      },
      {
        "command": "cagan.config.edit",
        "title": "cagan: Edit Config"
      },
      {
        "command": "cagan.cost.show",
        "title": "cagan: Show Cost"
      }
    ],
    "views": [
      {
        "id": "cagan-sidebar",
        "name": "cagan",
        "type": "webview"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cagan-activitybar",
          "title": "cagan",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "cagan.agent.run",
          "when": "workspaceFolderExists"
        }
      ]
    }
  },
  "dependencies": {
    "@cagan/core": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.90.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "typescript": "^5.4.0",
    "@vscode/test-electron": "^2.4.0"
  }
}